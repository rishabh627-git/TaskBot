<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Date selector bar: horizontal scrolling chips + calendar icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface">

        <HorizontalScrollView
            android:id="@+id/hsvDates"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <!-- Chips added programmatically -->
            <LinearLayout
                android:id="@+id/llChips"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </HorizontalScrollView>

        <!-- Calendar picker button -->
        <TextView
            android:id="@+id/btnCalendar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="📅"
            android:textSize="20sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- Selected date label -->
    <TextView
        android:id="@+id/tvSelectedDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"/>

    <!-- Task list for selected date -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvHistoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="24dp"
        android:text="No history yet.\n\nClear the ESP32 memory after\na session to save it here."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone"/>

</LinearLayout>